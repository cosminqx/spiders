# ── Seek Digital Intelligence — Environment Variables ─────────────────────
# Copy this to .env and fill in your real values.
# NEVER commit .env to git.

# Zyte API key (from app.zyte.com → Account → API Keys)
ZYTE_API_KEY=your_zyte_api_key_here

# Airtable (optional — enables direct push without CSV import)
# Base ID: from your Airtable URL — airtable.com/YOUR_BASE_ID/...
AIRTABLE_API_KEY=your_airtable_api_key_here
AIRTABLE_BASE_ID=your_base_id_here

# Notification webhook (optional — e.g. Slack or Make.com webhook)
# Triggered at end of each spider run with a summary
WEBHOOK_URL=https://hook.eu1.make.com/your_webhook_here
